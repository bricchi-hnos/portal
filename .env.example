# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://portal.bricchi.com
NEXTAUTH_SECRET=          # openssl rand -base64 32

# ── Magic Link Email (SMTP) ───────────────────────────────────────────────────
# Opción A: Gmail (cuenta de servicio)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=noreply@bricchi.com     # o cualquier cuenta Gmail
EMAIL_SERVER_PASSWORD=                    # App Password de Google (no la contraseña normal)
EMAIL_FROM=Bricchi Dashboards <noreply@bricchi.com>

# Opción B: Resend (recomendado, más fácil — gratis hasta 3000 emails/mes)
# EMAIL_SERVER_HOST=smtp.resend.com
# EMAIL_SERVER_PORT=465
# EMAIL_SERVER_USER=resend
# EMAIL_SERVER_PASSWORD=re_xxxxxxxxxxxx   # API key de resend.com
# EMAIL_FROM=Bricchi Dashboards <onboarding@resend.dev>

# ── Whitelist de emails habilitados ──────────────────────────────────────────
ALLOWED_EMAILS=nicolas@bricchi.com,alvaro@bricchi.com,alejandro@bricchi.com,juan@bricchi.com,andrea@bricchi.com,alejo@bricchi.com,francisco@bricchi.com

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxx            # Fine-grained PAT: Contents R/W en bricchi-hnos/dashboards
GITHUB_OWNER=bricchi-hnos
GITHUB_REPO=dashboards
GITHUB_BRANCH=main

# ── Supabase (auditoría) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=               # service_role key (NO anon)

# ── Dashboards base URL ───────────────────────────────────────────────────────
DASHBOARDS_BASE_URL=https://dashboards.bricchi.com
